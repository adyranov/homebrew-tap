{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices", "helpers:pinGitHubActionDigests"],
  timezone: "Etc/UTC",
  prConcurrentLimit: 5,
  labels: ["dependencies"],
  packageRules: [
    {
      description: "Update ggml-metal-dist Homebrew formulae together",
      matchManagers: ["homebrew"],
      matchPackageNames: ["adyranov/ggml-metal-dist"],
      groupName: "ggml-metal-dist formulae",
      groupSlug: "ggml-metal-dist-formulae",
      minimumReleaseAge: "2 days",
      addLabels: ["homebrew"],
      commitMessageTopic: "ggml-metal-dist formulae",
      commitMessageExtra: "({{newVersion}})",
    },
    {
      description: "Bulk pre-commit hook updates monthly",
      matchManagers: ["pre-commit"],
      groupName: "pre-commit hooks",
      groupSlug: "pre-commit-hooks",
      schedule: ["before 6am on the first day of the month"],
      addLabels: ["pre-commit"],
      commitMessageTopic: "pre-commit hooks",
      commitMessageExtra: "({{groupName}})",
    },
    {
      description: "Bulk GitHub Actions updates monthly",
      matchManagers: ["github-actions"],
      groupName: "github-actions",
      groupSlug: "github-actions",
      schedule: ["before 6am on the first day of the month"],
      commitMessageTopic: "GitHub Actions",
      commitMessageExtra: "({{groupName}})",
    },
  ],
}
