{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices", "helpers:pinGitHubActionDigests"],
  timezone: "Etc/UTC",
  prConcurrentLimit: 5,
  labels: ["dependencies"],
  // The built-in homebrew manager only reads the first url/sha256 pair and assumes
  // release assets named like repo-version.tar.gz. Our dual-arch ggml-metal-dist
  // tarballs need the custom regex manager + bump script below instead.
  customManagers: [
    {
      description: "ggml-metal-dist release version (canary: llama-cpp)",
      customType: "regex",
      managerFilePatterns: ["/^Formula/llama-cpp\\.rb$/"],
      matchStrings: [
        "releases/download/(?<currentValue>v[0-9.]+)/llama-cpp-(?:v[0-9.]+)-",
      ],
      depNameTemplate: "adyranov/ggml-metal-dist",
      datasourceTemplate: "github-releases",
      versioningTemplate: "semver",
      // {{{newValue}}} (raw/unescaped) replaces both the release-path
      // version and the filename-embedded version captured in the match.
      autoReplaceStringTemplate: "releases/download/{{{newValue}}}/llama-cpp-{{{newValue}}}-",
    },
  ],
  packageRules: [
    {
      description: "Disable homebrew manager for ggml-metal-dist (unsupported URL layout)",
      matchManagers: ["homebrew"],
      matchPackageNames: ["adyranov/ggml-metal-dist"],
      enabled: false,
    },
    {
      description: "Update ggml-metal-dist Homebrew formulae together",
      matchManagers: ["custom.regex"],
      matchDepNames: ["adyranov/ggml-metal-dist"],
      groupName: "ggml-metal-dist formulae",
      groupSlug: "ggml-metal-dist-formulae",
      addLabels: ["homebrew"],
      commitMessageTopic: "ggml-metal-dist formulae",
      commitMessageExtra: "({{newVersion}})",
    },
    {
      description: "Bulk pre-commit hook updates monthly",
      matchManagers: ["pre-commit"],
      groupName: "pre-commit hooks",
      groupSlug: "pre-commit-hooks",
      schedule: ["before 6am on the first day of the month"],
      addLabels: ["pre-commit"],
      commitMessageTopic: "monthly pre-commit hooks",
    },
    {
      description: "Bulk GitHub Actions updates monthly",
      matchManagers: ["github-actions"],
      groupName: "github-actions",
      groupSlug: "github-actions",
      schedule: ["before 6am on the first day of the month"],
      commitMessageTopic: "monthly GitHub Actions",
    },
  ],
}
